{
  "name": "ticket-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Decision-support tool for spotting concerts likely to have strong resale value. No auto-purchasing.",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "server": "tsx src/server/index.ts",
    "refresh": "tsx src/scripts/refresh.ts",
    "ticketmaster:test": "tsx src/scripts/test-ticketmaster.ts",
    "attraction:test": "tsx src/scripts/test-attraction.ts",
    "watchlist": "tsx src/scripts/watchlist.ts",
    "seatgeek:test": "tsx src/scripts/test-seatgeek.ts",
    "venues": "tsx src/scripts/venues.ts",
    "score": "tsx src/scripts/score.ts",
    "presale": "tsx src/scripts/presale.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^26.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
