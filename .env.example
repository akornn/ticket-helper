# Copy this file to .env and fill in your own keys. Never commit .env.

# Ticketmaster Discovery API
# Get a free key at https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# SeatGeek Platform API
# Get free credentials at https://seatgeek.com/build/api/access-info
# (SeatGeek issues a "client_id" and, for some access levels, a "client_secret")
SEATGEEK_CLIENT_ID=
SEATGEEK_CLIENT_SECRET=

# Local SQLite database file location
DB_PATH=./data/ticket-helper.db

# Dashboard web server port
PORT=4310

# Watchlist discovery defaults (used by auto-discovery, optional overrides)
# Comma-separated Ticketmaster classification/segment names, e.g. "Music"
TM_DEFAULT_SEGMENT=Music
# Comma-separated two-letter country codes for event search, e.g. "US"
TM_DEFAULT_COUNTRY_CODE=US
